<section class="hero animate">
  <div class="hero-inner">
    <div class="badges">
      <span class="badge">CISSP</span>
      <span class="badge">AZ-500</span>
      <span class="badge">Security+</span>
      <span class="badge usmc">USMC Veteran</span>
    </div>
    <h1>Carlos Miyares <span class="iv">IV</span></h1>
    <p class="tagline">Technology, Security &amp; Risk Management Professional</p>
    <p class="location">Fort Lauderdale, FL</p>
    <p class="summary">
      Senior security analyst with a proven track record in HITRUST, SOC II, and PCI accreditation.
      Specializing in IAM, cloud security, and enterprise digital transformation across organizations
      supporting 5,000+ users. USMC veteran.
    </p>
    <div class="cta">
      <a href="mailto:miyarescarlosiv@icloud.com" class="btn-primary">Get In Touch</a>
      <a href="https://www.linkedin.com/in/carlos-miyares-68a50a57/" target="_blank" class="btn-secondary">LinkedIn</a>
    </div>
  </div>
  <div class="glow"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 80px 24px;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, #0d1f3c 0%, var(--bg) 70%);
  }

  .glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(88, 166, 255, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    margin-bottom: 24px;
  }

  .badge {
    background: var(--accent-dim);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 20px;
    letter-spacing: 0.5px;
    border: 1px solid rgba(88, 166, 255, 0.2);
  }

  .badge.usmc {
    background: rgba(63, 185, 80, 0.15);
    color: var(--accent2);
    border-color: rgba(63, 185, 80, 0.2);
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -1px;
    line-height: 1.1;
    margin-bottom: 12px;
  }

  .iv { color: var(--accent); }

  .tagline {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: var(--muted);
    font-weight: 400;
    margin-bottom: 6px;
  }

  .location {
    font-size: 0.85rem;
    color: var(--dim);
    margin-bottom: 24px;
  }

  .summary {
    font-size: 0.95rem;
    color: var(--muted);
    max-width: 560px;
    margin: 0 auto 36px;
    line-height: 1.8;
  }

  .cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
    font-weight: 600;
    padding: 12px 28px;
    border-radius: 6px;
    font-size: 0.9rem;
    transition: opacity 0.2s;
    text-decoration: none;
  }

  .btn-primary:hover { opacity: 0.85; text-decoration: none; }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    font-weight: 500;
    padding: 12px 28px;
    border-radius: 6px;
    font-size: 0.9rem;
    border: 1px solid var(--border);
    transition: border-color 0.2s;
    text-decoration: none;
  }

  .btn-secondary:hover { border-color: var(--accent); text-decoration: none; }
</style>
