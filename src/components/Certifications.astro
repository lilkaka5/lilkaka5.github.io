---
import { Icon } from 'astro-icon/components';

const certs = [
  {
    code: 'CISSP',
    name: 'Certified Information Systems Security Professional',
    issuer: 'ISC2',
    tier: 'gold',
    icon: null,
    imgSrc: '/isc2.svg',
    iconColor: '#5CB85C',
    backDetail:
      'Globally recognized gold standard in information security. Covers 8 CISSP domains.',
  },
  {
    code: 'AZ-500',
    name: 'Azure Security Engineer Associate',
    issuer: 'Microsoft',
    tier: 'gold',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
    backDetail:
      'Demonstrates expertise in managing security posture, identity, and cloud workloads on Azure.',
  },
  {
    code: 'SEC+',
    name: 'Security+',
    issuer: 'CompTIA',
    tier: 'silver',
    icon: 'simple-icons:comptia',
    iconColor: '#C8202F',
    iconBg: 'rgba(200, 32, 47, 0.12)',
    backDetail:
      'DoD 8570 baseline certification covering core cybersecurity skills and best practices.',
  },
  {
    code: 'AZ-104',
    name: 'Azure Administrator',
    issuer: 'Microsoft',
    tier: 'silver',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
    backDetail:
      'Validates skills in managing Azure subscriptions, storage, VMs, and virtual networking.',
  },
  {
    code: 'CCENT',
    name: 'Cisco Certified Entry Networking Technician',
    issuer: 'Cisco',
    tier: 'silver',
    icon: 'simple-icons:cisco',
    iconColor: '#1BA0D7',
    backDetail:
      'Foundation-level Cisco certification in IP addressing, routing, and network fundamentals.',
  },
  {
    code: 'MD-101',
    name: 'Managing Modern Desktops',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
    backDetail: 'Covers deploying, configuring, securing, and managing modern Windows desktops.',
  },
  {
    code: 'MD-100',
    name: 'Windows 10',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
    backDetail:
      'Validates skills in installing, configuring, and maintaining Windows 10 environments.',
  },
  {
    code: 'SC-900',
    name: 'Security, Compliance & Identity Fundamentals',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
    backDetail:
      'Entry-level certification covering Microsoft security, compliance, and identity concepts.',
  },
  {
    code: '70-346',
    name: 'Managing Office 365 Identities & Requirements',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
    backDetail: 'Covers planning, deploying, and managing Office 365 identities and requirements.',
  },
  {
    code: '70-347',
    name: 'Enabling Office 365 Services',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
    backDetail: 'Validates skills in enabling and managing core Office 365 services and features.',
  },
  {
    code: 'AZ-900',
    name: 'Azure Fundamentals',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
    backDetail: 'Foundational Azure certification covering cloud concepts, services, and pricing.',
  },
  {
    code: 'MDA',
    name: 'Modern Desktop Administrator',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
    backDetail:
      'Associate-level role certification for planning and deploying modern desktop environments.',
  },
];

const tierLabel: Record<string, string> = {
  gold: 'Expert',
  silver: 'Associate',
  base: 'Foundational',
};
---

<section class="section animate delay-3">
  <div class="container">
    <h2 class="section-title">Certifications</h2>
    <div class="cert-grid">
      {
        certs.map((c) => (
          <div
            class={`flip-card cert-${c.tier}`}
            tabindex="0"
            role="button"
            aria-label={`${c.code} - ${c.name}`}
          >
            <div class="flip-inner">
              {/* Front */}
              <div class="flip-face flip-front">
                {c.imgSrc ? (
                  <img src={c.imgSrc} class="cert-icon" alt={c.issuer} />
                ) : (
                  <span
                    class="cert-icon-wrap"
                    style={c.iconBg ? `background: ${c.iconBg}` : undefined}
                  >
                    <Icon name={c.icon!} class="cert-icon" style={`color: ${c.iconColor}`} />
                  </span>
                )}
                <div class="cert-info">
                  <p class="cert-name">
                    <span class="cert-code">{c.code}</span> {c.name}
                  </p>
                  <p class="cert-issuer">{c.issuer}</p>
                </div>
              </div>
              {/* Back */}
              <div class="flip-face flip-back">
                <div class="back-tier-badge">{tierLabel[c.tier]}</div>
                <p class="back-detail">{c.backDetail}</p>
                <p class="back-issuer">
                  {c.issuer} · {c.code}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section {
    padding: 80px 24px;
    border-top: 1px solid var(--border);
  }
  .container {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 32px;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 10px;
  }

  /* Flip card container */
  .flip-card {
    height: 88px;
    perspective: 900px;
    cursor: pointer;
    border-radius: 8px;
    outline: none;
  }

  .flip-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.4, 0.2, 0.2, 1);
  }

  .flip-card:hover .flip-inner,
  .flip-card:focus-visible .flip-inner {
    transform: rotateY(180deg);
  }

  .flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
  }

  /* Tier left border colors */
  .cert-gold .flip-face {
    border-left: 3px solid #f0b429;
  }
  .cert-silver .flip-face {
    border-left: 3px solid var(--accent);
  }
  .cert-base .flip-face {
    border-left: 3px solid var(--dim);
  }

  /* Front face */
  .flip-front {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
  }

  .cert-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .cert-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .cert-code {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    background: var(--surface2);
    padding: 2px 7px;
    border-radius: 4px;
    color: var(--text);
    margin-right: 6px;
  }

  .cert-name {
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.4;
  }

  .cert-issuer {
    font-size: 0.78rem;
    color: var(--dim);
    margin-top: 2px;
  }

  /* Back face */
  .flip-back {
    transform: rotateY(180deg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 14px 18px;
    gap: 6px;
    background: var(--surface2);
  }

  .back-tier-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    width: fit-content;
  }

  .cert-gold .back-tier-badge {
    color: #f0b429;
    background: rgba(240, 180, 41, 0.12);
  }

  .back-detail {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .back-issuer {
    font-size: 0.72rem;
    color: var(--dim);
  }
</style>
