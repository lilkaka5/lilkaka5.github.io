---
import { Icon } from 'astro-icon/components';

const certs = [
  {
    code: 'CISSP',
    name: 'Certified Information Systems Security Professional',
    issuer: 'ISC2',
    tier: 'gold',
    icon: null,
    imgSrc: '/isc2.svg',
    iconColor: '#5CB85C',
  },
  {
    code: 'AZ-500',
    name: 'Azure Security Engineer Associate',
    issuer: 'Microsoft',
    tier: 'gold',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
  },
  {
    code: 'SEC+',
    name: 'Security+',
    issuer: 'CompTIA',
    tier: 'silver',
    icon: 'simple-icons:comptia',
    iconColor: '#C8202F',
  },
  {
    code: 'AZ-104',
    name: 'Azure Administrator',
    issuer: 'Microsoft',
    tier: 'silver',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
  },
  {
    code: 'CCENT',
    name: 'Cisco Certified Entry Networking Technician',
    issuer: 'Cisco',
    tier: 'silver',
    icon: 'simple-icons:cisco',
    iconColor: '#1BA0D7',
  },
  {
    code: 'MD-101',
    name: 'Managing Modern Desktops',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
  },
  {
    code: 'MD-100',
    name: 'Windows 10',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
  },
  {
    code: 'SC-900',
    name: 'Security, Compliance & Identity Fundamentals',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
  },
  {
    code: '70-346',
    name: 'Managing Office 365 Identities & Requirements',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
  },
  {
    code: '70-347',
    name: 'Enabling Office 365 Services',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
  },
  {
    code: 'AZ-900',
    name: 'Azure Fundamentals',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
  },
  {
    code: 'MDA',
    name: 'Modern Desktop Administrator',
    issuer: 'Microsoft',
    tier: 'base',
    icon: 'simple-icons:microsoft',
    iconColor: '#00A4EF',
  },
];
---

<section class="section animate delay-3">
  <div class="container">
    <h2 class="section-title">Certifications</h2>
    <div class="cert-grid">
      {
        certs.map((c) => (
          <div class={`cert cert-${c.tier}`}>
            {c.imgSrc ? (
              <img src={c.imgSrc} class="cert-icon" alt={c.issuer} />
            ) : (
              <Icon name={c.icon!} class="cert-icon" style={`color: ${c.iconColor}`} />
            )}
            <div class="cert-info">
              <p class="cert-name">
                <span class="cert-code">{c.code}</span> {c.name}
              </p>
              <p class="cert-issuer">{c.issuer}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section {
    padding: 80px 24px;
    border-top: 1px solid var(--border);
  }
  .container {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 32px;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 10px;
  }

  .cert {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    transition:
      border-color 0.2s,
      transform 0.2s;
  }

  .cert:hover {
    transform: translateY(-2px);
  }

  .cert-gold {
    border-left: 3px solid #f0b429;
  }
  .cert-silver {
    border-left: 3px solid var(--accent);
  }
  .cert-base {
    border-left: 3px solid var(--dim);
  }

  .cert-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .cert-code {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    background: var(--surface2);
    padding: 2px 7px;
    border-radius: 4px;
    color: var(--text);
    margin-right: 6px;
  }

  .cert-name {
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.4;
  }

  .cert-issuer {
    font-size: 0.78rem;
    color: var(--dim);
    margin-top: 2px;
  }
</style>
