---
import { Icon } from 'astro-icon/components';

const skills = [
  { label: 'Identity & Access Management', icon: 'lucide:key-round' },
  { label: 'Cybersecurity Compliance & Governance', icon: 'lucide:shield-check' },
  { label: 'Security Operations & Incident Response', icon: 'lucide:shield-alert' },
  { label: 'Cloud Security & Azure Governance', icon: 'lucide:cloud' },
  { label: 'Enterprise Digital Transformation', icon: 'lucide:zap' },
  { label: 'Automation & Process Optimization', icon: 'lucide:settings-2' },
  { label: 'Vulnerability Management & Threat Analysis', icon: 'lucide:scan-search' },
  { label: 'Vendor & Third-Party Risk Management', icon: 'lucide:handshake' },
];

const tools = [
  // Security & Monitoring
  'Microsoft Sentinel',
  'Microsoft Defender Suite',
  'SentinelOne EDR',
  'Proofpoint',
  'Orca Security',
  'Arctic Wolf',
  'Microsoft Purview',
  'Defender for Cloud Apps',
  'ZScaler',
  'Microsoft eDiscovery',
  // Cloud & Identity
  'Microsoft Entra ID',
  'Azure Policy',
  'Azure Security Center',
  'Azure Monitor',
  'Azure Key Vault',
  'Azure Identity Governance',
  'Azure Resource Manager',
  'Intune',
  'Conditional Access',
  'MFA / SSO',
  'YubiKey',
  // Automation & Scripting
  'PowerShell',
  'Python',
  'KQL',
  'Azure Logic Apps',
  'Power Automate',
  'Azure Functions',
  // Compliance & Service Management
  'HITRUST',
  'SOC II',
  'PCI-DSS',
  'Vanta',
  'ZenDesk',
  'Jira',
  'ServiceNow',
];
---

<section class="section animate delay-1">
  <div class="container">
    <h2 class="section-title">Core Competencies</h2>
    <div class="skills-grid">
      {
        skills.map((s) => (
          <div class="skill-card">
            <Icon name={s.icon} class="skill-icon" />
            <span>{s.label}</span>
          </div>
        ))
      }
    </div>

    <h3 class="tools-title">Tools & Technologies</h3>
    <div class="tools">
      {tools.map((t) => <span class="tool">{t}</span>)}
    </div>
  </div>
</section>

<style>
  .section {
    padding: 80px 24px;
    border-top: 1px solid var(--border);
  }
  .container {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 32px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
    margin-bottom: 48px;
  }

  .skill-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 0.88rem;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }

  .skill-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    cursor: pointer;
  }

  .skill-icon {
    width: 20px;
    height: 20px;
    color: var(--accent);
    flex-shrink: 0;
  }

  .tools-title {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 16px;
  }

  .tools {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tool {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.82rem;
    padding: 4px 12px;
    border-radius: 4px;
  }
</style>
